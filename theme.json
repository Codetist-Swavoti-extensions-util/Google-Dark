{
  "name": "Google Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#202124",
    "editor.foreground": "#E8EAED",
    "editor.lineHighlightBackground": "#303134",
    "editorCursor.foreground": "#8AB4F8",
    
    "sideBar.background": "#17181A",
    "sideBar.foreground": "#9AA0A6",
    "sideBar.border": "#3C4043",
    
    "activityBar.background": "#17181A",
    "activityBar.foreground": "#8AB4F8",
    
    "tab.activeBackground": "#202124",
    "tab.inactiveBackground": "#17181A",
    "tab.activeBorderTop": "#8AB4F8"
  },
  "tokenColors": [
    {
      "scope": ["keyword", "storage", "modifier"],
      "settings": {
        "foreground": "#8AB4F8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["string", "string.template"],
      "settings": {
        "foreground": "#81C995"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#FDE293"
      }
    },
    {
      "scope": ["variable", "variable.parameter"],
      "settings": {
        "foreground": "#E8EAED"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": {
        "foreground": "#F28B82"
      }
    },
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#9AA0A6",
        "fontStyle": "italic"
      }
    }
  ]
}
